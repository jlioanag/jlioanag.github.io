---
import Suspense from "./Suspense.astro";

const card = await fetch("https://api.scryfall.com/cards/random")
  .then((response) => response.json())
  .catch((error) => console.error("Error fetching card:", error));
---

<span
  class="underline decoration-wavy cursor-pointer transition-all duration-300 hover:opacity-75"
  id="randomCard"
>
  trading card games</span
>.

<div
  id="popup"
  class="w-75 fixed bg-brown-100 border border-brown-300 p-3 rounded shadow-lg z-50 hidden pointer-events-none text-sm"
>
  <p class="mb-3 text-justify">
    <span id="unicodeLeft"></span> Random magic card <span id="unicodeRight"
    ></span>
  </p>
  <div class="border border-brown-600 rounded overflow-hidden">
    <img src={card.image_uris.border_crop} alt={card.name} class="w-full" />
  </div>
</div>

<script>
  const unicodeChars = "⼆⅂⁠Ⳡ✣⥪√⹹⾔ⴝ⯎⣜⮙—⮶⾱⪈╴▵⥜⇀ⷕ∔⯸❾⊩⺰⛈";

  function getRandomChar() {
    return unicodeChars[Math.floor(Math.random() * unicodeChars.length)];
  }

  function generateRandomChars(count = 3) {
    return Array(count)
      .fill(0)
      .map(() => getRandomChar())
      .join("");
  }

  function updateUnicodeChars() {
    document.getElementById("unicodeLeft").textContent = generateRandomChars();
    document.getElementById("unicodeRight").textContent = generateRandomChars();
  }

  const card = document.getElementById("randomCard");
  const popup = document.getElementById("popup");

  card.addEventListener("click", async () => {
    try {
      const response = await fetch("https://api.scryfall.com/cards/random");
      const newCard = await response.json();
      const img = popup.querySelector("img");
      img.src = newCard.image_uris.border_crop;
      img.alt = newCard.name;
      updateUnicodeChars();
    } catch (error) {
      console.error("Error fetching new card:", error);
    }
  });

  card.addEventListener("mouseenter", () => {
    popup.classList.remove("hidden");
  });

  card.addEventListener("mouseleave", () => {
    popup.classList.add("hidden");
  });

  card.addEventListener("mousemove", (e) => {
    const x = e.clientX + 25;
    const y = e.clientY + 25;
    popup.style.left = x + "px";
    popup.style.top = y + "px";
    updateUnicodeChars();
  });
</script>
