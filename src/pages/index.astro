---
import "@/styles/global.css";
import Navbar from "@/components/Navbar.astro";
import Link from "@/components/Link.astro";

const card = await fetch("https://api.scryfall.com/cards/random")
  .then((response) => response.json())
  .catch((error) => console.error("Error fetching card:", error));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>julian's website</title>
  </head>
  <body class="in-h-screen">
    <Navbar />
    <div class="grid grid-cols-12 mx-auto text-left lg:px-50 px-5 py-15 gap-5">
      <p
        class="col-span-12 border border-brown-400 p-5 w-full sm:text-2xl text-sm"
      >
        Full stack developer currently working with React and <Link
          nav="https://backstage.io/"
          text="Backstage.io"
        />. Graduated from Rensselaer Polytechnic Institute with M.S. in Information Technology<sup
          >(2023)</sup
        > and B.S. in Computer Science<sup>(2022)</sup>. My hobbies include
        music, coffee, backpacking, biking, photography, and
        <span
          class="underline decoration-wavy cursor-pointer transition-all duration-300 hover:opacity-75"
          id="randomCard"
        >
          trading card games</span
        >.
      </p>

      <div
        class="border border-brown-400 xl:col-span-4 col-span-12 p-5 w-full sm:text-xl text-sm"
      >
        <p class="text-brown-700!">UBS</p>
        <i class="sm:text-lg text-xs">Software Engineer</i>
        <p class="text-brown-500! sm:text-lg text-xs">2023 to present</p>
      </div>
      <div
        class="border border-brown-400 xl:col-span-4 col-span-12 p-5 w-full sm:text-xl text-sm"
      >
        <p class="text-brown-700!">United Airlines</p>
        <i class="sm:text-lg text-xs">Stats & Ops Intern</i>
        <p class="text-brown-500! sm:text-lg text-xs">2022</p>
      </div>
      <div
        class="border border-brown-400 xl:col-span-4 col-span-12 p-5 w-full sm:text-xl text-sm"
      >
        <p class="text-brown-700!">The Cigna Group</p>
        <i class="sm:text-lg text-xs">Software Engineer Intern</i>
        <p class="text-brown-500! sm:text-lg text-xs">2021</p>
      </div>
    </div>

    <div
      id="popup"
      class="w-75 fixed bg-brown-100 border border-brown-300 p-3 rounded shadow-lg z-50 hidden pointer-events-none text-sm"
    >
      <p class="mb-3 text-justify">
        <span id="unicodeLeft"></span> Random magic card <span id="unicodeRight"
        ></span>
      </p>
      <div class="border border-brown-600 rounded overflow-hidden">
        <img src={card.image_uris.border_crop} alt={card.name} class="w-full" />
      </div>
    </div>

    <script>
      const unicodeChars = "⼆⅂⁠Ⳡ✣⥪√⹹⾔ⴝ⯎⣜⮙—⮶⾱⪈╴▵⥜⇀ⷕ∔⯸❾⊩⺰⛈";

      function getRandomChar() {
        return unicodeChars[Math.floor(Math.random() * unicodeChars.length)];
      }

      function generateRandomChars(count = 3) {
        return Array(count)
          .fill(0)
          .map(() => getRandomChar())
          .join("");
      }

      function updateUnicodeChars() {
        document.getElementById("unicodeLeft").textContent =
          generateRandomChars();
        document.getElementById("unicodeRight").textContent =
          generateRandomChars();
      }

      const cardLink = document.getElementById("randomCard");
      const popup = document.getElementById("popup");

      cardLink.addEventListener("click", async () => {
        try {
          const response = await fetch("https://api.scryfall.com/cards/random");
          const newCard = await response.json();
          const img = popup.querySelector("img");
          img.src = newCard.image_uris.border_crop;
          img.alt = newCard.name;
          updateUnicodeChars();
        } catch (error) {
          console.error("Error fetching new card:", error);
        }
      });

      cardLink.addEventListener("mouseenter", () => {
        popup.classList.remove("hidden");
      });

      cardLink.addEventListener("mouseleave", () => {
        popup.classList.add("hidden");
      });

      cardLink.addEventListener("mousemove", (e) => {
        const x = e.clientX + 25;
        const y = e.clientY + 25;
        popup.style.left = x + "px";
        popup.style.top = y + "px";
        updateUnicodeChars();
      });
    </script>
  </body>
</html>
